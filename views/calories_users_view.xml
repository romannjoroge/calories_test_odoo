<odoo>
    <record id="calorie_form_view" model="ir.ui.view">
        <field name="name">test_calories_app.calories.users.view.form</field>
        <field name="model">calories.users</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="height"/>
                        <field name="weight"/>
                        <field name="calories"/>
                    </group>
                    <group>
                        <field name="physical_activty"/>
                        <field name="goal"/>
                        <field name="manager_id" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="calorie_listing" model="ir.ui.view">
        <field name="name">test_calories_app.calories.users.view.tree</field>
        <field name="model">calories.users</field>
        <field name="arch" type="xml">
            <list>
                <field name="height" />
                <field name="weight" />
                <field name="physical_activty" />
                <field name="calories"/>
                <field name="manager_id" />
                <field name="manager_calories" />
            </list>
        </field>
    </record>

    <record id="calorie_manager_listing" model="ir.ui.view">
        <field name="name">test_calories_app.calories.managers.view.list</field>
        <field name="model">calories.managers</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="recommendations_ids"/>
                <field name="total_calories"/>
            </list>
        </field>
    </record>

    <record id="calorie_recommendation" model="ir.actions.act_window">
        <field name="name">Get Recommendations</field>
        <field name="res_model">calories.users</field>
        <field name="view_mode">form</field>
    </record>

    <record id="calorie_previous_recommendations" model="ir.actions.act_window">
        <field name="name">Previous Recommendations</field>
        <field name="res_model">calories.users</field>
        <field name="view_mode">list</field>
    </record>

    <record id="calorie_managers_view" model="ir.actions.act_window">
        <field name="name">View Managers</field>
        <field name="res_model">calories.managers</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>