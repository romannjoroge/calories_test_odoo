    <record id="view_calorie_profile_form" model="ir.ui.view">
        <field name="name">calorie.profile.form</field>
        <field name="model">calorie.profile</field>
        <field name="arch" type="xml">
            <form string="Profile" duplicate="0" create="0" class="container">
                <header class="row">
                    <div class="col">
                        <h1>Hello, <field name="user_id" readonly="1" /></h1>
                    </div>

                    <div class="col d-flex justify-content-center">
                        <button type="object" name="action_add_meal" icon="oi-plus"
                            help="Add a meal" string="Add meal" />
                    </div>
                </header>

                <div class="card mb-8 p-3">
                    <h2>Daily Calories</h2>
                    <group class="col">
                        <field name="calories_consumed_today" readonly="1" />
                        <field name="daily_calorie_budget" readonly="1" />
                        <field name="calories_remaining_today" readonly="1" />
                        <field name="calories_consumed_progress" readonly="1" widget="progressbar" />
                    </group>
                </div>

                <sheet>
                    <group>
                        <group>
                            <field name="sex" />
                            <field name="age" />
                            <field name="height_cm" />
                        </group>
                        <group>
                            <field name="weight_kg" />
                            <field name="activity_level" />
                            <field name="goal" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Meals">
                            <field name="meal_ids" readonly="1">
                                <list edit="0">
                                    <field name="food_name" />
                                    <field name="datetime_consumed" />
                                    <field name="calories" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_calorie_profile_list" model="ir.ui.view">
        <field name="name">calorie.profile.list</field>
        <field name="model">calorie.profile</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id" />
                <field name="daily_calorie_budget" />
                <field name="calories_consumed_today" />
                <field name="calories_remaining_today" />
            </list>
        </field>
    </record>
</odoo>